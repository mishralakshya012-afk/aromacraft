<!DOCTYPE html>
<html>
<head>
    <title>AromaCraft</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
    <h2>AromaCraft 🌿</h2>
    <a href="/products">Products</a>

    <% if(user){ %>
        <a href="/cart">Cart</a>

        <!-- Secure Logout (POST method) -->
        <form action="/auth/logout" method="POST" style="display:inline;">
            <button type="submit" 
                style="background:none;border:none;color:blue;cursor:pointer;font-size:16px;">
                Logout
            </button>
        </form>

    <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
    <% } %>
</nav>
<hr>
