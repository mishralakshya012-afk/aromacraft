
<h1 class="mb-4">Dashboard</h1>

<div class="row">

    <!-- Products -->
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-primary shadow">
            <div class="card-body">
                <h5><i class="fas fa-box me-2"></i>Products</h5>
                <h3><%= totalProducts %></h3>
            </div>
        </div>
    </div>

    <!-- Orders -->
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-success shadow">
            <div class="card-body">
                <h5><i class="fas fa-shopping-cart me-2"></i>Orders</h5>
                <h3><%= totalOrders %></h3>
            </div>
        </div>
    </div>

    <!-- Users -->
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-warning shadow">
            <div class="card-body">
                <h5><i class="fas fa-users me-2"></i>Users</h5>
                <h3><%= totalUsers %></h3>
            </div>
        </div>
    </div>

    <!-- Revenue -->
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-danger shadow">
            <div class="card-body">
                <h5><i class="fas fa-dollar-sign me-2"></i>Revenue</h5>
                <h3>$<%= totalRevenue %></h3>
            </div>
        </div>
    </div>

</div>


<div class="card shadow mt-4">

    <div class="card-header">
        <h5>Recent Orders</h5>
    </div>

    <div class="card-body">

        <table class="table table-striped">

            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>User</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>

                <% if(recentOrders.length > 0){ %>

                    <% recentOrders.forEach(order => { %>

                        <tr>
                            <td><%= order._id %></td>
                            <td><%= order.user %></td>
                            <td>$<%= order.total %></td>
                            <td><%= order.status %></td>
                        </tr>

                    <% }) %>

                <% } else { %>

                    <tr>
                        <td colspan="4">No orders yet</td>
                    </tr>

                <% } %>

            </tbody>

        </table>

    </div>

</div>