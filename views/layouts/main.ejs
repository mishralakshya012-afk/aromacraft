<!DOCTYPE html>
<html>
<head>
  <title>AromaCraft</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="d-flex flex-column min-vh-100">

<!-- Navbar -->
<% if (!url || !url.startsWith("/auth")) { %>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">

    <a class="navbar-brand" href="/">AromaCraft</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <ul class="navbar-nav me-auto">

        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/products">Shop</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/products/categories">Categories</a>
        </li>

      </ul>

      <ul class="navbar-nav">

        <li class="nav-item">
          <a class="nav-link" href="/cart/checkout">Cart</a>
        </li>

        <% if(user){ %>

        <li class="nav-item">
          <a href="/orders/my-orders" class="nav-link <%= url.includes('orders') ? 'active' : '' %>">
  My Orders
</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/auth/logout">Logout</a>
        </li>

        <% } else { %>

        <li class="nav-item">
          <a class="nav-link" href="/auth/login">Login</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/auth/register">Register</a>
        </li>

        <% } %>

      </ul>

    </div>

  </div>
</nav>

<% } %>
<!-- Page Content -->
<main class="flex-grow-1">
  <%- body %>
</main>

<!-- Footer -->
<footer class="bg-dark text-white text-center py-3 mt-auto">
  <p>© 2026 AromaCraft | All Rights Reserved</p>
</footer>

</body>
</html>