
<h2 style="text-align:center;">Shop by Category</h2>

<% if (user && user.role === "admin") { %>
  <div style="text-align:center; margin-bottom:20px;">
    <a href="/products/add">
      <button style="background:#dc3545; color:white; padding:10px 20px; border:none; border-radius:5px;">
        Add Product
      </button>
    </a>
  </div>
<% } %>

<div class="category-container">

  <% categories.forEach(cat => { %>

    <a href="/products/category/<%= cat.name %>" class="category-card">

      <!-- IMAGE -->
      <img src="/images/categories/<%= cat.image %>" alt="<%= cat.name %>">

      <!-- OVERLAY -->
      <div class="category-overlay">
        <h3><%= cat.name %></h3>
      </div>

    </a>

  <% }) %>

</div>

