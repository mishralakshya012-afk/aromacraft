<div class="container mt-5">

  <h2 class="mb-4">Shopping Cart</h2>

  <% if(cart.length === 0){ %>

    <p>Your cart is empty.</p>
    <a href="/products" class="btn btn-primary">Continue Shopping</a>

  <% } else { %>

  <table class="table table-bordered align-middle">

    <thead class="table-dark">
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Total</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>

      <% cart.forEach(item => { %>

      <tr>

        <!-- PRODUCT -->
        <td class="d-flex align-items-center gap-3">

          <% if(item.image){ %>
          <img src="/uploads/<%= item.image %>" 
               width="60" height="60"
               style="object-fit:cover; border-radius:5px;">
          <% } %>

          <span><%= item.name %></span>

        </td>

        <!-- PRICE -->
        <td>₹ <%= item.price %></td>

        <!-- QUANTITY -->
        <td>

          <form action="/cart/decrease/<%= item.productId %>" method="POST" style="display:inline;">
            <button class="btn btn-sm btn-danger">−</button>
          </form>

          <span class="mx-2"><%= item.qty %></span>

          <form action="/cart/increase/<%= item.productId %>" method="POST" style="display:inline;">
            <button class="btn btn-sm btn-success">+</button>
          </form>

        </td>

        <!-- TOTAL -->
        <td>₹ <%= item.price * item.qty %></td>

        <!-- REMOVE -->
        <td>

          <form action="/cart/remove/<%= item.productId %>" method="POST">
            <button class="btn btn-sm btn-warning">Remove</button>
          </form>

        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

  <!-- GRAND TOTAL -->
 <div class="text-end border-top pt-3">

  <h4 class="mb-3">Total: ₹ <%= total %></h4>

  <a href="/cart/checkout" class="btn btn-dark px-4">
    Proceed to Checkout
  </a>

</div>

  <% } %>

</div>