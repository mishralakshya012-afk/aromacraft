<h2 style="text-align:center;"><%= category %> Products</h2>

<div class="product-container">

<% products.forEach(product => { %>

<div class="card">

<h3>
<a href="/products/<%= product._id %>">
<%= product.name %>
</a>
</h3>

<p>₹ <%= product.price %></p>

<a href="/products/<%= product._id %>">
<button>View Details</button>
</a>

</div>

<% }) %>

</div>