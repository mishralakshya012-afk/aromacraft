<div class="container mt-5">

  <div class="row">

    <!-- LEFT: IMAGE -->
    <div class="col-md-6">
      <% if(product.image){ %>
      <img src="/uploads/<%= encodeURIComponent(product.image) %>">
           class="img-fluid rounded shadow"
           style="width:100%; height:400px; object-fit:cover;">
      <% } %>
    </div>

    <!-- RIGHT: DETAILS -->
    <div class="col-md-6">

      <h2 class="mb-3"><%= product.name %></h2>

      <h4 class="text-success mb-3">₹ <%= product.price %></h4>

      <p class="text-muted">
        Category: <strong><%= product.category %></strong>
      </p>

      <!-- 🔥 FIXED DESCRIPTION -->
      <div class="product-description mt-3">
  <%- product.description 
        ? product.description.replace(/\n/g, "<br>").replace(/\*/g, "•") 
        : "No description available" %>
</div>

      <p class="mt-3">
        <strong>Stock:</strong> 
        <% if(product.stock > 0){ %>
          <span class="text-success">In Stock</span>
        <% } else { %>
          <span class="text-danger">Out of Stock</span>
        <% } %>
      </p>

      <!-- ADD TO CART -->
      <% if(product.stock > 0){ %>
      <form action="/cart/add-to-cart/<%= product._id %>" method="POST">
        <button class="btn btn-dark btn-lg mt-3">
          Add to Cart
        </button>
      </form>
      <% } else { %>
      <button class="btn btn-secondary mt-3" disabled>
        Out of Stock
      </button>
      <% } %>

    </div>

  </div>

</div>